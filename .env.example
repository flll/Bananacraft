# Streamlit Auth (Optional)
STREAMLIT_PASSWORD=

# Google Gemini キー: https://aistudio.google.com/apikey
# OpenAI キー: https://platform.openai.com/api-keys
# Anthropic キー: https://console.anthropic.com/settings/keys
# Streamlit ドキュメント: https://docs.streamlit.io/
# Minecraft server.properties（RCON）: https://minecraft.wiki/w/Server.properties
# --- Google (Gemini / 画像) ---
GEMINI_API_KEY=

# --- OpenAI（区画 JSON・建築 FC・インフラ FC）---
OPENAI_API_KEY=

# --- Anthropic（コンセプト対話・装飾 FC）---
ANTHROPIC_API_KEY=

# --- Tripo3D（画像→3D メッシュ、Mesh-First Architect）---
# https://platform.tripo3d.ai （キーは tsk_ で始まる）
TRIPO_API_KEY=

# 各プロバイダは上記 1 本ずつ。OpenAI / Anthropic が無い工程は GEMINI_API_KEY で動作します。

# --- RCON（Bananacraft → Minecraft）---
# 既定は `make up`（stack）で UI コンテナから接続する想定。
# `make dev`（ホストで Streamlit を起動）するときは RCON_HOST=localhost に変更してください。
RCON_HOST=minecraft
RCON_PORT=28889
RCON_PASSWORD=bananacraft

# --- Mineflayer ボット（AI_Carpenter_Bot）---
# `make dev` のとき localhost、`make up` のとき compose 内 DNS で minecraft を使う
MC_HOST=minecraft
MC_PORT=28888

# --- Docker Minecraft（itzg + Purpur。バージョンは docker-compose.yml で 26.1.2 固定）---
# https://hub.docker.com/r/itzg/minecraft-server
MC_MEMORY=4G
MC_ONLINE_MODE=FALSE
MC_MAX_PLAYERS=10
MC_DIFFICULTY=normal

# --- BlueMap（ワールドを 3D Web マップで閲覧する任意プラグイン）---
# true にすると Modrinth から bluemap も取得され、http://localhost:${BLUEMAP_PORT} で表示できる。
# Bananacraft の RCON 設置や .schem 配置には不要。
ENABLE_BLUEMAP=false
BLUEMAP_PORT=8100

# --- WorldEdit + RCON で .schem を配置するときのワールド名 ---
# itzg/minecraft-server の既定は "world"。LEVEL を変更している場合のみ書き換える。
# UI の「WorldEdit で配置 (.schem)」が //world <name> を発行する際に使う。
BANANACRAFT_MC_WORLD=world

# Docker 内 Bananacraft の実行ユーザー（./projects の所有者と揃える）
DOCKER_UID=1000
DOCKER_GID=1000
