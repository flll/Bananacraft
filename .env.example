# Streamlit Auth (Optional)
STREAMLIT_PASSWORD=

# Google Gemini キー: https://aistudio.google.com/apikey
# OpenAI キー: https://platform.openai.com/api-keys
# Anthropic キー: https://console.anthropic.com/settings/keys
# Streamlit ドキュメント: https://docs.streamlit.io/
# Minecraft server.properties（RCON）: https://minecraft.wiki/w/Server.properties
# --- Google (Gemini / 画像) ---
GEMINI_API_KEY=

# --- OpenAI（区画 JSON・建築 FC・インフラ FC）---
OPENAI_API_KEY=

# --- Anthropic（コンセプト対話・装飾 FC）---
ANTHROPIC_API_KEY=

# 各プロバイダは上記 1 本ずつ。OpenAI / Anthropic が無い工程は GEMINI_API_KEY で動作します。

# --- RCON（Bananacraft → Minecraft。make mc-up / stack-up 時は itzg イメージが同じ値を使用）---
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=bananacraft

# --- Docker Minecraft（itzg/minecraft-server。make mc-up / stack-up）---
# https://hub.docker.com/r/itzg/minecraft-server
MC_TYPE=VANILLA
MC_VERSION=LATEST
MC_MEMORY=4G
MC_ONLINE_MODE=FALSE
MC_MAX_PLAYERS=10
MC_DIFFICULTY=normal

# Docker 内 Bananacraft の実行ユーザー（./projects の所有者と揃える。PermissionError 時は make fix-projects-perms）
DOCKER_UID=1000
DOCKER_GID=1000
