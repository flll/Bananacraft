# マシン固有の Cursor / Tailscale 認証（Git 管理外）
# コピー先: ~/.cursor/.env
#
# TS_AUTHKEY は tag:bananacraft 付きの reusable キーを推奨。
# 発行: https://login.tailscale.com/admin/settings/keys
# またはリモートで: make tailscale-keys（要 secret.env の TS_API_ACCESS_TOKEN）
#
# ACL 前提: infra/tailscale-acl-snippet.json の tagOwners を
# https://login.tailscale.com/admin/acls に追加済みであること。

TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
