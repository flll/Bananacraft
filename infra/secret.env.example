# テンプレ — 実値は GSM cursor-secret（lll-fish）または ~/.cursor/secrets/secret.env
# GitHub は gh auth login のみ（GITHUB_TOKEN は載せない）
# Tailnet 鍵は ~/.cursor/.env（infra/cursor.env.example）

# --- Tailscale ---
#   A) API token: https://login.tailscale.com/admin/settings/keys
TS_API_ACCESS_TOKEN=
#   B) OAuth: https://login.tailscale.com/admin/settings/trust-credentials
TS_OAUTH_CLIENT_ID=
TS_OAUTH_CLIENT_SECRET=
TAILNET=your-tailnet.ts.net
# 推奨: TS_AUTHKEY は ~/.cursor/.env に（ここには書かない）

# --- Cloudflare（任意）---
# User API Token: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Docker Hub（任意）---
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# GCP: gcloud auth login 済みなら GOOGLE_APPLICATION_CREDENTIALS 不要
